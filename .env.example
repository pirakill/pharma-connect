# Infivita PharmaConnect — copy to .env for Docker or local production

PHARMACONNECT_SECRET=change-me-in-production
PHARMACONNECT_DB=sqlite:////data/pharmaconnect.db
PHARMACONNECT_CRON_SECRET=change-me-cron-secret

# PostgreSQL (docker compose -f docker-compose.yml -f docker-compose.postgres.yml up):
# PHARMACONNECT_DB=postgresql+psycopg://pharma:pharma@postgres:5432/pharmaconnect

# Optional: gunicorn workers (docker-compose sets this)
# GUNICORN_WORKERS=2